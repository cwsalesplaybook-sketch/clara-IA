{
  "manifest_version": 3,
  "name": "ClarIA — Assistente Comercial CW",
  "description": "Assistente de vendas da Cardápio Web. Ativa apenas no Sales Playbook.",
  "version": "1.1.0",
  "permissions": ["storage"],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["knowledge_base.js", "claria.js"],
      "css": ["claria.css"],
      "run_at": "document_end"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["icons/icon16.png", "icons/icon48.png", "icons/icon128.png"],
      "matches": ["<all_urls>"]
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
